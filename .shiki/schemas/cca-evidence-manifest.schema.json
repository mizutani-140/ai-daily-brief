{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shiki.local/schemas/cca-evidence-manifest.schema.json",
  "title": "Shiki CCA Evidence Manifest",
  "type": "object",
  "required": [
    "version",
    "kind",
    "repository",
    "pr",
    "head_sha",
    "workflow",
    "artifact",
    "files",
    "verdict",
    "created_at"
  ],
  "properties": {
    "version": { "const": 1 },
    "kind": { "const": "shiki-cca-evidence-manifest" },
    "repository": { "type": "string", "minLength": 1 },
    "pr": { "type": "integer", "minimum": 1 },
    "head_sha": { "type": "string", "minLength": 7 },
    "workflow": {
      "type": "object",
      "required": ["name", "run_id", "run_attempt", "job", "event_name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 },
        "run_attempt": { "type": "string", "minLength": 1 },
        "job": { "type": "string", "minLength": 1 },
        "event_name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "artifact": {
      "type": "object",
      "required": ["name", "path", "uploaded_by"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "uploaded_by": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "sha256", "required"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "required": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "verdict": {
      "type": "object",
      "required": ["verdict", "goal_id", "task_id", "pr", "head_sha"],
      "properties": {
        "verdict": { "type": "string", "minLength": 1 },
        "goal_id": { "type": "string", "minLength": 1 },
        "task_id": { "type": "string", "minLength": 1 },
        "pr": { "type": "integer", "minimum": 1 },
        "head_sha": { "type": "string", "minLength": 7 }
      },
      "additionalProperties": true
    },
    "created_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": true
}
